# Copy to `.env` for local `pnpm dev` and for Docker Compose variable substitution.
#   cp .env.example .env
# Compose reads this file automatically when you run `docker compose` from the repo root.
#
# Local dev (`pnpm dev`): keep CACHE_TYPE=memory unless you run Redis locally.
# Docker (`docker compose -f docker-compose.sunbi-rsshub.yml up -d`): use redis service URL below.

# Bind to loopback only in local dev (default upstream listens on all interfaces).
LISTEN_INADDR_ANY=0

# --- Required for SPEC-protected feeds (same pattern as upstream ACCESS_KEY) ---
# All feed URLs must include `?key=<ACCESS_KEY>` when set.
ACCESS_KEY=replace-with-openssl-rand-hex-32

# --- Cache ---
# memory | redis
CACHE_TYPE=memory
# Used when CACHE_TYPE=redis (Docker hostname is `redis`; localhost dev example shown)
REDIS_URL=redis://localhost:6379/

# --- Optional tuning (production-oriented) ---
# CACHE_EXPIRE=600
# CACHE_CONTENT_EXPIRE=3600
# REQUEST_TIMEOUT=20000
# REQUEST_RETRY=2

# --- Optional platform auth (routes that need them) ---
# WEVERSE_TOKEN=
# NETFLIX_COOKIE=
# NAVER_COOKIE=
# BUBBLE_COOKIE=

# --- Optional outbound proxy ---
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,redis
